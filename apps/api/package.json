    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/multer": "^1.4.11",
    "@types/sanitize-html": "^2.9.5",
    "@types/supertest": "^6.0.2",
